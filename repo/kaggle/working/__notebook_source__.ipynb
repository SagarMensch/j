import subprocess
result = subprocess.run(["tesseract", "--version"], capture_output=True, text=True)
print(result.stdout or result.stderr)

import fitz                          # PyMuPDF — renders pages natively, no poppler
import pytesseract
import json, uuid, re
import numpy as np
from PIL import Image
from sentence_transformers import SentenceTransformer
from tqdm import tqdm
from pathlib import Path
from collections import Counter

# ================================================================
# CONFIG
# ================================================================
PDF_FILES = {
    "SOP-CHM-001": "/kaggle/input/jubilant-docs/SOP-CHM-001_v2.1.pdf",
    "SMP-MNT-002": "/kaggle/input/jubilant-docs/SMP-MNT-002_v1.3.pdf",
    "WID-SAF-003":  "/kaggle/input/jubilant-docs/WID-SAF-003_v1.0.pdf",
}
DOC_SUPABASE_IDS = {
    "SOP-CHM-001": "10000000-0000-0000-0000-000000000001",
    "SMP-MNT-002": "10000000-0000-0000-0000-000000000002",
    "WID-SAF-003":  "10000000-0000-0000-0000-000000000003",
}

WORDS_PER_CHUNK    = 350
WORDS_OVERLAP      = 70
# OCR render resolution — 200 DPI is a good balance of accuracy vs speed
# For very small text bump this to 250 or 300
OCR_DPI            = 200
SCANNED_THRESHOLD  = 30   # pages with fewer extractable words → treated as scanned
EMBEDDING_MODEL    = "sentence-transformers/all-MiniLM-L6-v2"
OUTPUT_DIR         = "/kaggle/working/"

# ================================================================
# Load embedding model once
# ================================================================
print("Loading MiniLM-L6-v2 …")
model = SentenceTransformer(EMBEDDING_MODEL)
print("Model ready.\n")


# ================================================================
# HELPERS
# ================================================================

def fitz_page_to_pil(page: fitz.Page, dpi: int = OCR_DPI) -> Image.Image:
    """
    Render a fitz page to a PIL Image using PyMuPDF's built-in renderer.
    No poppler, no pdf2image — fitz does it all.
    """
    zoom   = dpi / 72          # 72 is PDF's native DPI
    matrix = fitz.Matrix(zoom, zoom)
    pix    = page.get_pixmap(matrix=matrix, alpha=False)
    # pix.samples is raw RGB bytes
    img    = Image.frombytes("RGB", [pix.width, pix.height], pix.samples)
    return img


def is_page_scanned(page: fitz.Page) -> bool:
    text       = page.get_text("text")
    word_count = len(text.split())
    return word_count < SCANNED_THRESHOLD


def extract_blocks_from_text_page(page: fitz.Page):
    """
    For a text-based PDF page: extract blocks with normalised bounding boxes.
    Returns list of {"text": str, "bbox_norm": (x0,y0,x1,y1)}
    """
    pw, ph = page.rect.width, page.rect.height
    blocks = []
    for block in page.get_text("blocks"):
        # (x0, y0, x1, y1, text, block_no, block_type)
        if block[6] != 0:          # skip image blocks
            continue
        text = block[4].strip()
        if not text:
            continue
        x0, y0, x1, y1 = block[0], block[1], block[2], block[3]
        blocks.append({
            "text":      text,
            "bbox_norm": (
                round(x0 / pw, 4),
                round(y0 / ph, 4),
                round(x1 / pw, 4),
                round(y1 / ph, 4),
            ),
        })
    return blocks


def extract_blocks_from_scanned_page(page: fitz.Page):
    """
    For a scanned (image-only) page: render with PyMuPDF → PIL,
    run Tesseract, group words into line-level blocks with bbox.
    Returns list of {"text": str, "bbox_norm": (x0,y0,x1,y1)}
    """
    pil_img = fitz_page_to_pil(page, dpi=OCR_DPI)
    iw, ih  = pil_img.size

    data    = pytesseract.image_to_data(
        pil_img,
        output_type=pytesseract.Output.DICT,
        config="--psm 3",
    )

    # Group words into lines by (block_num, par_num, line_num)
    lines   = {}
    n       = len(data["text"])
    for i in range(n):
        word = data["text"][i].strip()
        conf = int(data["conf"][i])
        if not word or conf < 30:
            continue
        key  = (data["block_num"][i], data["par_num"][i], data["line_num"][i])
        l, t, w, h = data["left"][i], data["top"][i], data["width"][i], data["height"][i]
        if key not in lines:
            lines[key] = {"words": [], "x0": l, "y0": t, "x1": l+w, "y1": t+h}
        else:
            lines[key]["x0"] = min(lines[key]["x0"], l)
            lines[key]["y0"] = min(lines[key]["y0"], t)
            lines[key]["x1"] = max(lines[key]["x1"], l + w)
            lines[key]["y1"] = max(lines[key]["y1"], t + h)
        lines[key]["words"].append(word)

    blocks = []
    for ld in lines.values():
        text = " ".join(ld["words"])
        if len(text) < 3:
            continue
        blocks.append({
            "text":      text,
            "bbox_norm": (
                round(ld["x0"] / iw, 4),
                round(ld["y0"] / ih, 4),
                round(ld["x1"] / iw, 4),
                round(ld["y1"] / ih, 4),
            ),
        })
    return blocks


def detect_heading(text: str):
    first = text.split("\n")[0].strip()
    if re.match(r'^(\d+[\.\d]*\s+)?[A-Z][A-Z\s\-&/]{3,60}$', first):
        return first
    if re.match(r'^\d+\.\d*\s+.{5,60}$', first):
        return first
    return None


def chunk_page_blocks(blocks, page_number: int):
    """
    Slide a window of WORDS_PER_CHUNK words over the blocks from one page.
    Each chunk carries:
      - page_number  → exact physical 1-based page (guaranteed correct)
      - bbox_norm    → union of all block bboxes contributing to this chunk
    """
    if not blocks:
        return []

    # Flatten words while remembering which block index each word came from
    words_with_block = []
    for bi, blk in enumerate(blocks):
        for word in blk["text"].split():
            words_with_block.append((word, bi))

    if not words_with_block:
        return []

    chunks   = []
    total    = len(words_with_block)
    start    = 0

    while start < total:
        end   = min(start + WORDS_PER_CHUNK, total)
        slice_ = words_with_block[start:end]

        chunk_text = " ".join(w for w, _ in slice_)
        if len(chunk_text.strip()) < 20:
            start += WORDS_PER_CHUNK - WORDS_OVERLAP
            continue

        # Union bounding box of all blocks that contributed words
        contrib_idxs = set(bi for _, bi in slice_)
        bboxes       = [blocks[bi]["bbox_norm"] for bi in contrib_idxs]
        merged       = (
            round(min(b[0] for b in bboxes), 4),
            round(min(b[1] for b in bboxes), 4),
            round(max(b[2] for b in bboxes), 4),
            round(max(b[3] for b in bboxes), 4),
        )

        # Try to find a heading at the top of this chunk
        first_block_text = blocks[min(contrib_idxs)]["text"]
        section_title    = detect_heading(first_block_text)

        chunks.append({
            "chunk_text":    chunk_text,
            "page_number":   page_number,   # ← always the physical 1-based page
            "bbox_x0":       merged[0],
            "bbox_y0":       merged[1],
            "bbox_x1":       merged[2],
            "bbox_y1":       merged[3],
            "section_title": section_title,
            "token_count":   len(chunk_text.split()),
        })

        start += WORDS_PER_CHUNK - WORDS_OVERLAP

    return chunks


# ================================================================
# MAIN LOOP — process each document page by page
# ================================================================
all_chunks = []

for doc_code, pdf_path in PDF_FILES.items():
    if not Path(pdf_path).exists():
        print(f"SKIP: {pdf_path} not found")
        continue

    print(f"\n{'='*60}")
    print(f"Processing: {doc_code}")
    print(f"  Path: {pdf_path}")

    pdf_doc     = fitz.open(pdf_path)
    total_pages = len(pdf_doc)
    print(f"  Total pages: {total_pages}")

    chunk_index   = 0
    scanned_count = 0

    for page_idx in tqdm(range(total_pages), desc=f"  Pages"):
        physical_page = page_idx + 1       # 1-based — exactly what pdfjs uses in frontend

        page    = pdf_doc[page_idx]
        scanned = is_page_scanned(page)

        if scanned:
            scanned_count += 1
            blocks = extract_blocks_from_scanned_page(page)
            method = "OCR"
        else:
            blocks = extract_blocks_from_text_page(page)
            method = "PDF"

        if not blocks:
            continue

        page_chunks = chunk_page_blocks(blocks, page_number=physical_page)

        for c in page_chunks:
            c["id"]                 = str(uuid.uuid4())
            c["document_id"]        = DOC_SUPABASE_IDS[doc_code]
            c["doc_code"]           = doc_code
            c["chunk_index"]        = chunk_index
            c["extraction_method"]  = method
            all_chunks.append(c)
            chunk_index += 1

    pdf_doc.close()
    print(f"  Done: {chunk_index} chunks | {scanned_count}/{total_pages} pages used OCR")

print(f"\nTotal chunks across all documents: {len(all_chunks)}")

# Sanity check — page number distribution
for doc_code in DOC_SUPABASE_IDS:
    doc_chunks = [c for c in all_chunks if c["doc_code"] == doc_code]
    if not doc_chunks:
        continue
    dist = Counter(c["page_number"] for c in doc_chunks)
    print(f"\n{doc_code} — chunks per page (verify these match your PDF):")
    for pg in sorted(dist):
        print(f"  Page {pg:3d}: {dist[pg]} chunk(s)")


# ================================================================
# EMBEDDINGS
# ================================================================
print("\nGenerating embeddings …")
BATCH_SIZE = 64
texts      = [c["chunk_text"] for c in all_chunks]
embeddings = []

for i in tqdm(range(0, len(texts), BATCH_SIZE), desc="Embedding batches"):
    vecs = model.encode(texts[i:i+BATCH_SIZE], normalize_embeddings=True).tolist()
    embeddings.extend(vecs)

print(f"Embeddings: {len(embeddings)} vectors, dim={len(embeddings[0])}")

for i, c in enumerate(all_chunks):
    c["embedding"] = embeddings[i]


# ================================================================
# SAVE
# ================================================================
out = f"{OUTPUT_DIR}chunks_with_embeddings.json"
with open(out, "w", encoding="utf-8") as f:
    json.dump(all_chunks, f, ensure_ascii=False, indent=2)

sz = Path(out).stat().st_size / 1024 / 1024
print(f"\nSaved → {out}  ({sz:.2f} MB)")

# Lightweight bbox-only file (no embeddings — small, good for debugging)
bbox_out = f"{OUTPUT_DIR}bounding_boxes.json"
with open(bbox_out, "w") as f:
    json.dump([
        {
            "chunk_id":          c["id"],
            "doc_code":          c["doc_code"],
            "document_id":       c["document_id"],
            "chunk_index":       c["chunk_index"],
            "page_number":       c["page_number"],
            "bbox_x0":           c["bbox_x0"],
            "bbox_y0":           c["bbox_y0"],
            "bbox_x1":           c["bbox_x1"],
            "bbox_y1":           c["bbox_y1"],
            "section_title":     c.get("section_title"),
            "extraction_method": c["extraction_method"],
        }
        for c in all_chunks
    ], f, indent=2)
print(f"Saved → {bbox_out}")
print("\nAll done. Download both files from the Kaggle Output tab.")
